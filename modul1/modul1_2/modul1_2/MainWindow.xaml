<Window x:Class="modul1_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:modul1_2"
        mc:Ignorable="d"
        Title="Hesap Makinesi" Height="450" Width="800">
    <Grid>
        <Label Content="1.Sayı:" HorizontalAlignment="Left" Margin="30,40,0,0" VerticalAlignment="Top"/>
        <Label Content="2.Sayı:" HorizontalAlignment="Left" Margin="30,80,0,0" VerticalAlignment="Top"/>
        <Label Content="Sonuç:" HorizontalAlignment="Left" Margin="30,120,0,0" VerticalAlignment="Top"/>

        <TextBox x:Name="textBox1" HorizontalAlignment="Left" Height="23" Margin="100,42,0,0" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="textBox2" HorizontalAlignment="Left" Height="23" Margin="100,82,0,0" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="textBox3" HorizontalAlignment="Left" Height="23" Margin="100,122,0,0" VerticalAlignment="Top" Width="120" IsReadOnly="True"/>

        <Button x:Name="btnTopla" Content="Topla" HorizontalAlignment="Left" Margin="250,40,0,0" VerticalAlignment="Top" Width="75" Click="btnTopla_Click"/>
        <Button x:Name="btnCikar" Content="Çıkar" HorizontalAlignment="Left" Margin="250,75,0,0" VerticalAlignment="Top" Width="75" Click="btnCikar_Click"/>
        <Button x:Name="btnCarp" Content="Çarp" HorizontalAlignment="Left" Margin="250,110,0,0" VerticalAlignment="Top" Width="75" Click="btnCarp_Click"/>
        <Button x:Name="btnBol" Content="Böl" HorizontalAlignment="Left" Margin="250,145,0,0" VerticalAlignment="Top" Width="75" Click="btnBol_Click"/>
    </Grid>
</Window>